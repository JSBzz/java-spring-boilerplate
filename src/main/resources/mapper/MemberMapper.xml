<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.jsb.boilerplate.mapper.MemberMapper">
    <select id="findByLoginId" resultType="com.jsb.boilerplate.model.Member">
        SELECT * FROM member WHERE login_id = #{loginId}
    </select>

    <insert id="save" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO member (
            login_id,
            password,
            name,
            email,
            role,
            status,
            created_at,
            updated_at
        ) VALUES (
            #{loginId},
            #{password},
            #{name},
            #{email},
            #{role},
            #{status},
            #{createdAt},
            #{updatedAt}
        )
    </insert>

</mapper>
